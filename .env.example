# Required: Apify API token for job board scraping
# Get one free at https://console.apify.com/sign-up
APIFY_API_TOKEN=

# Optional: Email notifications via Resend (https://resend.com)
RESEND_API_KEY=

# Optional: Supabase cloud storage (https://supabase.com)
# If not set, SQLite is used automatically (zero config)
SUPABASE_URL=
SUPABASE_KEY=

# Optional: Decision maker enrichment
PROSPEO_API_KEY=
ANYMAILFINDER_API_KEY=

# Optional: Cold email drafting via Claude
ANTHROPIC_API_KEY=

# Optional: Google Sheets integration
# Set paths for local dev, or JSON strings for CI
GOOGLE_CREDENTIALS_PATH=
GOOGLE_TOKEN_PATH=
